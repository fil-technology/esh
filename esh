#!/usr/bin/env bash
set -euo pipefail

SOURCE_PATH="$0"
while [[ -L "$SOURCE_PATH" ]]; do
  LINK_TARGET="$(readlink "$SOURCE_PATH")"
  if [[ "$LINK_TARGET" = /* ]]; then
    SOURCE_PATH="$LINK_TARGET"
  else
    SOURCE_PATH="$(cd "$(dirname "$SOURCE_PATH")" && cd "$(dirname "$LINK_TARGET")" && pwd)/$(basename "$LINK_TARGET")"
  fi
done

SELF_DIR="$(cd "$(dirname "$SOURCE_PATH")" && pwd)"

if [[ -x "$SELF_DIR/scripts/run.sh" ]]; then
  exec "$SELF_DIR/scripts/run.sh" "$@"
fi

if [[ -x "$SELF_DIR/share/esh/scripts/run.sh" ]]; then
  exec "$SELF_DIR/share/esh/scripts/run.sh" "$@"
fi

echo "error: unable to locate esh launcher support files." >&2
exit 1
